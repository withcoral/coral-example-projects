# Model selection — defaults to bedrock:minimax.minimax-m2.5. Override with any
# pydantic-ai model string (e.g. `anthropic:claude-sonnet-4-6`).
SRE_AGENT_MODEL=

# Anthropic — used when SRE_AGENT_MODEL routes through `anthropic:`.
ANTHROPIC_API_KEY=

# AWS Bedrock — used when SRE_AGENT_MODEL routes through `bedrock:`.
# AWS_BEARER_TOKEN_BEDROCK is the canonical env name boto3 looks for. boto3's
# session also requires AWS_DEFAULT_REGION (AWS_REGION alone isn't enough).
AWS_REGION=eu-west-1
AWS_DEFAULT_REGION=eu-west-1
AWS_BEARER_TOKEN_BEDROCK=

# Slack bot runtime. Use Socket Mode for local demos.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Coral Slack connector reads SLACK_TOKEN. The Python code and scripts fall back
# to SLACK_BOT_TOKEN when this is unset.
SLACK_TOKEN=

# Datadog (Coral needs both the API key and the Application key)
DD_API_KEY=
DD_APPLICATION_KEY=
DD_SITE=

# GitHub
GITHUB_TOKEN=
GITHUB_ORG=
GITHUB_REPO=

# Sentry — Coral reads via SENTRY_TOKEN (auth token with org/project/event read).
SENTRY_TOKEN=
SENTRY_ORG=
SENTRY_BASE_URL=https://sentry.io

# Demo "hello-service" FastAPI app — DSN it uses to ship events INTO Sentry.
# Distinct from SENTRY_TOKEN above, which is for reading Sentry's API.
SENTRY_DSN=

# Coral
CORAL_BIN=coral
